<%- include('../partials/header') %>

<div class="dashboard-banner" style="background: linear-gradient(135deg, #1f2937, #111827); margin-bottom: 30px;">
    <div class="banner-title" style="background: linear-gradient(90deg, #3b82f6, #60a5fa); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">Reading Test Result</div>
    <div class="banner-subtitle">Detailed Performance Analysis</div>
</div>

<!-- Score Header -->
<div style="text-align: center; margin-bottom: 40px; background: rgba(13, 17, 23, 0.5); padding: 40px; border-radius: 12px; border: 1px solid #30363d;">
    
    <div style="font-size: 1.2rem; color: #8b949e; margin-bottom: 10px;">Total Score</div>
    <div style="font-size: 4rem; font-weight: 800; color: white; line-height: 1;">
        <%= result.totalScore %> <span style="font-size: 2rem; color: #8b949e; font-weight: 400;">/ <%= result.maxScore %></span>
    </div>
    
    <div style="margin-top: 20px;">
        <% const percentage = (result.totalScore / result.maxScore) * 100; %>
        <div style="max-width: 300px; height: 10px; background: #21262d; border-radius: 5px; margin: 0 auto; overflow: hidden;">
            <div style="width: <%= percentage %>%; height: 100%; background: <%= percentage >= 70 ? '#3fb950' : (percentage >= 40 ? '#d29922' : '#f85149') %>;"></div>
        </div>
        <div style="margin-top: 10px; color: <%= percentage >= 70 ? '#3fb950' : (percentage >= 40 ? '#d29922' : '#f85149') %>; font-weight: 600;">
            <%= percentage.toFixed(1) %>% Accuracy
        </div>
    </div>

    <a href="/reading/student/dashboard" class="btn btn-secondary" style="margin-top: 30px; display: inline-block;">Return to Dashboard</a>

    <% if (typeof user !== 'undefined' && user.role === 'admin') { %>
        <form action="/reading/admin/result/delete/<%= result._id %>" method="POST" style="display: inline-block; margin-left: 10px;" onsubmit="return confirm('ADMIN ACTION: Permanently delete this result?');">
            <button type="submit" class="btn" style="background: rgba(218, 54, 51, 0.1); color: #f85149; border: 1px solid #da3633; padding: 10px 20px;">
                Delete Result 🗑️
            </button>
        </form>
    <% } %>
</div>

<!-- Detailed Analysis -->
<div style="display: flex; justify-content: space-between; align-items: baseline; border-bottom: 1px solid #30363d; padding-bottom: 10px; margin-bottom: 20px;">
    <h3 style="color: #e6edf3; margin: 0;">Passage Breakdown</h3>
    <span style="font-size: 0.9rem; color: #8b949e; background: #161b22; padding: 4px 10px; border-radius: 20px; border: 1px solid #30363d;">
        ✨ AI Credits Left: <strong style="color: #4ade80;" class="ai-credits-span"><%= user && user.readingAiCredits !== undefined ? user.readingAiCredits : '?' %></strong>
    </span>
</div>

<% result.passages.forEach((pRef, pIdx) => { %>
    <div style="background: #0d1117; border: 1px solid #30363d; border-radius: 8px; margin-bottom: 30px; overflow: hidden;">
        
        <!-- Passage Header Score -->
        <div style="padding: 15px 20px; background: #161b22; border-bottom: 1px solid #30363d; display: flex; justify-content: space-between; align-items: center;">
            <h4 style="margin: 0; color: #e6edf3;">Passage <%= pIdx + 1 %>: <%= pRef.passageId.title %></h4>
            <span style="background: #21262d; padding: 4px 10px; border-radius: 20px; color: #e6edf3; font-weight: 600;">
                Score: <%= pRef.passageScore %>/<%= pRef.passageId.questions.length %>
            </span>
        </div>

        <!-- AI Actions Toolbar -->
        <div style="padding: 10px 20px; background: #0d1117; border-bottom: 1px solid #30363d; display: flex; gap: 10px; flex-wrap: wrap;">
            <button class="ai-action-btn" onclick="performAIAction(this, 'translate', <%= pIdx %>, `<%= pRef.passageId.content.replace(/`/g, '\\`').replace(/\n/g, '\\n') %>`)">
                🌐 Translate (Hindi)
            </button>
            <button class="ai-action-btn" onclick="performAIAction(this, 'summarize', <%= pIdx %>, `<%= pRef.passageId.content.replace(/`/g, '\\`').replace(/\n/g, '\\n') %>`)">
                📝 Summarize
            </button>
            <button class="ai-action-btn" onclick="performAIAction(this, 'highlight_answers', <%= pIdx %>, `<%= pRef.passageId.content.replace(/`/g, '\\`').replace(/\n/g, '\\n') %>`)">
                🖍️ Highlight Key Info
            </button>
            <button class="ai-action-btn" onclick="performAIAction(this, 'difficult_words', <%= pIdx %>, `<%= pRef.passageId.content.replace(/`/g, '\\`').replace(/\n/g, '\\n') %>`)">
                📚 Hard Words & Meanings
            </button>
        </div>

        <div id="ai-result-<%= pIdx %>" class="ai-result-box" style="margin: 0 20px 15px 20px; display: none;"></div>

        <!-- Content Preview -->
        <div style="padding: 15px 20px; font-size: 0.95rem; color: #c9d1d9; border-bottom: 1px solid #30363d; background: #0d1117; line-height: 1.6;">
            <div id="content-<%= pIdx %>" data-original="<%= pRef.passageId.content %>" style="max-height: 60px; overflow: hidden; transition: max-height 0.3s;">
                <%= pRef.passageId.content %>
            </div>
            <button onclick="togglePassageContent(<%= pIdx %>)" style="background: none; border: none; color: #58a6ff; cursor: pointer; padding: 0; margin-top: 5px; font-size: 0.85rem;">
                Toggle Full Passage ▼
            </button>
        </div>

        <!-- Questions Review -->
        <div style="padding: 20px;">
            <% pRef.passageId.questions.forEach((q, qIdx) => { %>
                <% 
                    const userAnsIdx = pRef.answers[qIdx];
                    const isCorrect = userAnsIdx === q.correctOption;
                    const isSkipped = userAnsIdx === -1;
                %>
                
                <div style="margin-bottom: 20px; padding-bottom: 20px; border-bottom: 1px solid #21262d;">
                    <div style="display: flex; gap: 10px; align-items: flex-start;">
                        <span style="font-size: 1.2rem;">
                            <%= isCorrect ? '✅' : '❌' %>
                        </span>
                        <div style="flex: 1;">
                            <strong style="color: #e6edf3; display: block; margin-bottom: 8px;">Q<%= qIdx+1 %>. <%= q.questionText %></strong>
                            
                            <!-- Options -->
                            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px;">
                                <% q.options.forEach((opt, optIdx) => { %>
                                    <% 
                                        let style = "padding: 8px; border-radius: 4px; font-size: 0.9rem; color: #8b949e; border: 1px solid #30363d;";
                                        
                                        // Highlight Logic
                                        if (optIdx === q.correctOption) {
                                            style = "padding: 8px; border-radius: 4px; font-size: 0.9rem; background: rgba(46, 160, 67, 0.15); color: #3fb950; border: 1px solid #3fb950;";
                                        } else if (optIdx === userAnsIdx && !isCorrect) {
                                            style = "padding: 8px; border-radius: 4px; font-size: 0.9rem; background: rgba(248, 81, 73, 0.15); color: #ff7b72; border: 1px solid #ff7b72;";
                                        }
                                    %>
                                    <div style="<%= style %>">
                                        <%= ['A','B','C','D'][optIdx] %>) <%= opt %>
                                        <% if (optIdx === userAnsIdx) { %> (You) <% } %>
                                        <% if (optIdx === q.correctOption) { %> (Correct) <% } %>
                                    </div>
                                <% }) %>
                            </div>

                            <!-- Explanation -->
                            <div style="margin-top: 10px; background: #161b22; padding: 10px; border-left: 3px solid #3b82f6; font-size: 0.9rem; color: #c9d1d9;">
                                <strong>Explanation:</strong> <%= q.explanation %>
                            </div>

                            <!-- AI Explain Answer Button -->
                            <% 
                                const qDataStr = `Question: ${q.questionText} | Options: ${q.options.join(', ')} | Correct Option Index: ${q.correctOption}`;
                            %>
                            <div style="margin-top: 10px;">
                                <button class="ai-action-btn" style="border-color: #8957e5; color: #a371f7;" 
                                    onclick="performAIAction(this, 'explain_answer', '<%= pIdx %>_<%= qIdx %>', `<%= pRef.passageId.content.replace(/`/g, '\\`').replace(/\n/g, '\\n') %>`, `<%= qDataStr.replace(/`/g, '\\`') %>`)">
                                    ✨ AI Detail Explanation
                                </button>
                                <div id="ai-result-<%= pIdx %>_<%= qIdx %>" class="ai-result-box" style="display: none; margin-top: 10px;"></div>
                            </div>
                        </div>
                    </div>
                </div>

            <% }) %>
        </div>

    </div>
<% }) %>

<!-- AI Feature Scripts -->
<style>
    .ai-action-btn {
        background: #1f2937;
        color: #e6edf3;
        border: 1px solid #30363d;
        padding: 5px 12px;
        border-radius: 6px;
        font-size: 0.85rem;
        cursor: pointer;
        transition: all 0.2s;
        display: inline-flex;
        align-items: center;
        gap: 5px;
    }
    .ai-action-btn:hover:not(:disabled) {
        border-color: #8b949e;
        background: #21262d;
    }
    .ai-action-btn:disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }
    .ai-result-box {
        margin-top: 15px;
        padding: 15px;
        background: rgba(137, 87, 229, 0.1);
        border: 1px solid #8957e5;
        border-radius: 8px;
        color: #e6edf3;
        font-size: 0.95rem;
        line-height: 1.6;
        display: none;
    }
    .ai-highlight {
        background-color: rgba(163, 113, 247, 0.3) !important;
        border-bottom: 2px solid #8957e5;
    }
</style>

<script>
    async function performAIAction(btn, action, pIdx, passageText, questionData = null) {
        const resultBox = document.getElementById(`ai-result-${pIdx}`);
        const contentBox = document.getElementById(`content-${pIdx}`);
        const originalContent = contentBox.dataset.original;

        btn.disabled = true;
        const originalText = btn.innerHTML;
        btn.innerHTML = '⏳ Thinking...';

        try {
            const response = await fetch('/reading/student/ai-action', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ action, passageText, questionId: questionData })
            });

            const data = await response.json();
            
            if (data.error) {
                alert(`❌ ${data.error}`);
            } else {
                // Update specific credit spans if they exist on the page
                document.querySelectorAll('.ai-credits-span').forEach(el => el.textContent = data.creditsLeft);

                if (action === 'highlight_answers') {
                    contentBox.innerHTML = data.reply;
                } else {
                    resultBox.style.display = 'block';
                    resultBox.innerHTML = `<strong>✨ AI Result:</strong><br><br>${data.reply.replace(/\\n/g, '<br>')}`;
                }
            }
        } catch (error) {
            alert('❌ Network error. Please try again.');
        }

        btn.disabled = false;
        btn.innerHTML = originalText;
    }

    function togglePassageContent(pIdx) {
        const el = document.getElementById(`content-${pIdx}`);
        if (el.style.maxHeight === '60px') {
            el.style.maxHeight = 'none';
        } else {
            el.style.maxHeight = '60px';
        }
    }
</script>

<%- include('../partials/footer') %>
