<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Evaluate University Exam | Faculty Panel</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #f8f9fa; }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark py-3 px-4 shadow-sm">
        <a href="/faculty/dashboard" class="btn btn-outline-light btn-sm me-3"><i class="bi bi-arrow-left"></i> Dashboard</a>
        <span class="navbar-brand mb-0 h1">Evaluate Exam</span>
    </nav>
    <div class="container mt-5 mb-5">
        <div class="card shadow-sm border-0 border-top border-4 border-primary">
            <div class="card-body p-5">
                <div class="row mb-4">
                    <div class="col-md-4">
                        <p class="text-muted mb-1">Student Name</p>
                        <h5 class="fw-bold"><%= registration.studentName %></h5>
                    </div>
                    <div class="col-md-4">
                        <p class="text-muted mb-1">Roll Number</p>
                        <h5 class="fw-bold text-primary"><%= registration.rollNumber %></h5>
                    </div>
                    <div class="col-md-4 text-md-end">
                        <p class="text-muted mb-1">Submitted On</p>
                        <h5 class="fw-bold"><%= new Date(registration.submittedAt).toLocaleString() %></h5>
                    </div>
                </div>

                <div class="mb-5">
                    <h6 class="text-uppercase fw-bold text-primary mb-3">Student Answer Text:</h6>
                    <div class="p-4 bg-light rounded" style="font-family: 'Courier New', monospace; font-size: 1rem; line-height: 1.6; white-space: pre-wrap; border: 1px solid #dee2e6; min-height: 150px;">
<%= registration.submission ? registration.submission : 'No text submission provided.' %>
                    </div>
                </div>

                <% if (registration.submissionFiles && registration.submissionFiles.length > 0) { %>
                <div class="mb-5">
                    <h6 class="text-uppercase fw-bold text-primary mb-3">Attached Files:</h6>
                    <div class="row g-3">
                        <% registration.submissionFiles.forEach((fileUrl, index) => { %>
                            <div class="col-md-4">
                                <a href="<%= fileUrl %>" target="_blank">
                                    <img src="<%= fileUrl %>" class="img-fluid rounded border shadow-sm" alt="Submission Image <%= index+1 %>">
                                </a>
                            </div>
                        <% }) %>
                    </div>
                </div>
                <% } else if (registration.submissionFile) { %>
                <div class="mb-5">
                    <h6 class="text-uppercase fw-bold text-primary mb-3">Attached File:</h6>
                    <a href="<%= registration.submissionFile %>" target="_blank">
                        <img src="<%= registration.submissionFile %>" class="img-fluid rounded border shadow-sm" style="max-width: 300px;" alt="Submission Image">
                    </a>
                </div>
                <% } %>

                <hr>

                <form action="/faculty/evaluate-exam/<%= registration._id %>" method="POST" class="mt-4">
                    <h5 class="fw-bold mb-3">Provide Evaluation</h5>
                    
                    <div class="mb-4">
                        <label class="form-label fw-bold">Marks Assigned</label>
                        <input type="number" name="marks" class="form-control form-control-lg w-25" placeholder="e.g. 85" required>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold">Remarks / Feedback</label>
                        <textarea name="remarks" class="form-control" rows="3" placeholder="Enter remarks..."></textarea>
                    </div>

                    <button type="submit" class="btn btn-primary btn-lg px-5">Submit Evaluation</button>
                    <a href="/faculty/dashboard" class="btn btn-outline-secondary btn-lg ms-2">Cancel</a>
                </form>
            </div>
        </div>
    </div>
</body>
</html>
