<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Evaluate Essay | Faculty Panel</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #f8f9fa; }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark py-3 px-4 shadow-sm">
        <a href="/faculty/dashboard" class="btn btn-outline-light btn-sm me-3"><i class="bi bi-arrow-left"></i> Dashboard</a>
        <span class="navbar-brand mb-0 h1">Evaluate Essay</span>
    </nav>
    <div class="container mt-5">
        <div class="card shadow-sm border-0 border-top border-4" style="border-top-color: #f472b6 !important;">
            <div class="card-body p-5">
                <div class="row mb-4">
                    <div class="col-md-6">
                        <p class="text-muted mb-1">Student</p>
                        <h5 class="fw-bold"><%= submission.user ? submission.user.name : 'Unknown' %></h5>
                    </div>
                    <div class="col-md-6 text-md-end">
                        <p class="text-muted mb-1">Submitted On</p>
                        <h5 class="fw-bold"><%= new Date(submission.createdAt).toLocaleString() %></h5>
                    </div>
                </div>

                <div class="mb-4">
                    <h6 class="text-uppercase fw-bold" style="color: #f472b6;">Topic:</h6>
                    <h4><%= submission.topic.topic %></h4>
                </div>

                <div class="mb-5">
                    <h6 class="text-uppercase fw-bold" style="color: #f472b6;">Essay Content:</h6>
                    <div class="p-4 bg-light rounded" style="font-family: 'Georgia', serif; font-size: 1.1rem; line-height: 1.8; white-space: pre-wrap; border: 1px solid #dee2e6;">
<%= submission.essayContent %>
                    </div>
                </div>

                <hr>

                <form action="/faculty/evaluate-essay/<%= submission._id %>" method="POST" class="mt-4">
                    <h5 class="fw-bold mb-3">Provide Evaluation</h5>
                    
                    <div class="mb-4">
                        <label class="form-label fw-bold">Score / Grade</label>
                        <input type="number" step="0.5" name="score" class="form-control form-control-lg w-25" placeholder="e.g. 8.5" required>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold">Feedback / Remarks</label>
                        <textarea name="feedback" class="form-control" rows="5" placeholder="Enter constructive feedback here..." required></textarea>
                    </div>

                    <button type="submit" class="btn btn-success btn-lg px-5">Submit Evaluation</button>
                    <a href="/faculty/dashboard" class="btn btn-outline-secondary btn-lg ms-2">Cancel</a>
                </form>
            </div>
        </div>
    </div>
</body>
</html>
