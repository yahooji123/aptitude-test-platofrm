<%- include('../partials/header') %>

<div class="dashboard-banner" style="background: linear-gradient(135deg, #7928ca 0%, #ff0080 100%);">
    <div class="banner-title">Coding Topics</div>
    <div class="banner-subtitle">Create topics and manage coding questions in bulk.</div>
</div>

<div class="container" style="max-width: 900px; margin: 0 auto; padding: 20px;">
    <% if (locals.success_msg) { %>
        <div class="alert alert-success" style="background: rgba(46, 160, 67, 0.15); border: 1px solid #3fb950; color: #3fb950; padding: 15px; border-radius: 6px; margin-bottom: 20px;">
            <%= success_msg %>
        </div>
    <% } %>
    <% if (locals.error_msg) { %>
        <div class="alert alert-danger" style="background: rgba(248, 81, 73, 0.1); border: 1px solid #f85149; color: #f85149; padding: 15px; border-radius: 6px; margin-bottom: 20px;">
            <%= error_msg %>
        </div>
    <% } %>

    <div class="card" style="background: #161b22; border: 1px solid #30363d; border-radius: 6px; padding: 24px; margin-bottom: 30px;">
        <h2 style="color: #c9d1d9; border-bottom: 1px solid #30363d; padding-bottom: 10px; margin-bottom: 20px;">Add New Topic</h2>
        <form action="/coding/admin/topics/add" method="POST">
            <div class="form-group" style="margin-bottom: 15px;">
                <label style="display: block; color: #8b949e; margin-bottom: 5px;">Topic Name</label>
                <input type="text" name="name" required class="form-control" style="width: 100%; padding: 8px; background: #0d1117; border: 1px solid #30363d; color: #c9d1d9; border-radius: 4px;">
            </div>
            <button type="submit" class="btn-primary" style="background: #7928ca; color: white; border: none; padding: 10px 20px; border-radius: 6px; cursor: pointer; font-size: 1rem;">Add Topic</button>
        </form>
    </div>

    <div style="background: #161b22; border: 1px solid #30363d; border-radius: 6px; overflow: hidden;">
        <div style="padding: 16px; background: #0d1117; border-bottom: 1px solid #30363d; display: flex; justify-content: space-between; align-items: center;">
            <h3 style="margin: 0; color: #c9d1d9;">All Topics</h3>
            <span style="background: #30363d; padding: 2px 8px; border-radius: 12px; font-size: 0.8rem; color: #8b949e;"><%= topics ? topics.length : 0 %> Topics</span>
        </div>
        <% if(topics && topics.length > 0) { %>
            <div style="max-height: 400px; overflow-y: auto;">
                <% topics.forEach(t => { %>
                    <div style="padding: 16px; border-bottom: 1px solid #30363d; display: flex; justify-content: space-between; align-items: center;">
                        <div style="color: #58a6ff; font-weight: 600; font-size: 1.1rem;"><%= t.name %></div>
                        <a href="/coding/admin/topics/<%= t._id %>" class="btn-primary" style="background: #bc8cff; color: white; border: none; padding: 6px 16px; border-radius: 6px; cursor: pointer; font-size: 0.95rem;">Bulk Add Questions</a>
                    </div>
                <% }) %>
            </div>
        <% } else { %>
            <div style="padding: 30px; text-align: center; color: #8b949e;">
                No topics added yet. Start by adding one above!
            </div>
        <% } %>
    </div>
</div>

<%- include('../partials/footer') %>
