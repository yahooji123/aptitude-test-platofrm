<%- include('../partials/header') %>

<div class="dashboard-banner" style="background: linear-gradient(135deg, #a371f7 0%, #d2a8ff 100%);">
    <div class="banner-title">Interview Completed</div>
    <div class="banner-subtitle">Subject: <%= session.subject %> • <%= session.totalQuestions %> Questions</div>
    <div style="margin-top: 15px;">
        <a href="/interview/setup" class="btn" style="background: rgba(255,255,255,0.2); color: white; border: none;">Start New Interview</a>
        <a href="/student/dashboard" class="btn" style="background: transparent; color: white; border: 1px solid white; margin-left: 10px;">Back to Home</a>
    </div>
</div>

<div class="container" style="max-width: 900px; margin-top: -30px; position: relative; z-index: 2;">
    
    <% 
        let tConf = 0, tComm = 0, tLog = 0;
        session.answers.forEach(a => { 
            tConf += a.confidenceScore; 
            tComm += a.communicationScore; 
            tLog += a.logicScore; 
        });
        const count = session.answers.length;
        const oConf = (tConf / count).toFixed(1);
        const oComm = (tComm / count).toFixed(1);
        const oLog = (tLog / count).toFixed(1);
        const overall = ((tConf + tComm + tLog) / (count * 3)).toFixed(1);
    %>

    <!-- Summary Score Card -->
    <div class="quiz-card" style="margin-bottom: 30px; display: flex; flex-wrap: wrap; gap: 20px; align-items: center; justify-content: space-around; text-align: center;">
        <div>
            <div style="font-size: 2.5rem; font-weight: 800; color: #a371f7;"><%= overall %><span style="font-size:1.2rem; color:var(--text-secondary)">/10</span></div>
            <div style="color: var(--text-secondary); font-weight: 600; text-transform: uppercase; font-size: 0.85rem; letter-spacing: 1px;">Overall Score</div>
        </div>
        <div style="height: 60px; width: 1px; background: var(--border-color);" class="mobile-hide"></div>
        <div>
            <div style="font-size: 1.8rem; font-weight: 700; color: #58a6ff;"><%= oConf %></div>
            <div style="color: var(--text-secondary); font-size: 0.85rem;">Confidence</div>
        </div>
        <div>
            <div style="font-size: 1.8rem; font-weight: 700; color: #3fb950;"><%= oComm %></div>
            <div style="color: var(--text-secondary); font-size: 0.85rem;">Communication</div>
        </div>
        <div>
            <div style="font-size: 1.8rem; font-weight: 700; color: #f472b6;"><%= oLog %></div>
            <div style="color: var(--text-secondary); font-size: 0.85rem;">Logical Reasoning</div>
        </div>
    </div>

    <h3 style="margin-bottom: 20px;">Detailed Feedback</h3>

    <% session.answers.forEach((ans, index) => { %>
        <div class="quiz-card" style="margin-bottom: 20px; border-top: 3px solid #30363d;">
            <div style="margin-bottom: 15px;">
                <span style="background: var(--bg-secondary); padding: 4px 10px; border-radius: 12px; font-size: 0.8rem; font-weight: 600; margin-bottom: 10px; display: inline-block;">Q <%= index + 1 %></span>
                <h4 style="margin: 0; font-size: 1.1rem;"><%= ans.question %></h4>
            </div>

            <div style="background: rgba(88, 166, 255, 0.05); border: 1px solid rgba(88, 166, 255, 0.2); padding: 15px; border-radius: 8px; margin-bottom: 15px;">
                <div style="font-size: 0.8rem; font-weight: 600; color: #58a6ff; margin-bottom: 5px;">YOUR ANSWER</div>
                <p style="margin: 0; line-height: 1.6;"><%= ans.answer %></p>
            </div>

            <div style="display: flex; gap: 15px; margin-bottom: 15px; flex-wrap: wrap;">
                <div style="background: var(--bg-body); border: 1px solid var(--border-color); padding: 8px 12px; border-radius: 6px; font-size: 0.9rem;">
                    Confidence: <strong style="color:#58a6ff"><%= ans.confidenceScore %>/10</strong>
                </div>
                <div style="background: var(--bg-body); border: 1px solid var(--border-color); padding: 8px 12px; border-radius: 6px; font-size: 0.9rem;">
                    Communication: <strong style="color:#3fb950"><%= ans.communicationScore %>/10</strong>
                </div>
                <div style="background: var(--bg-body); border: 1px solid var(--border-color); padding: 8px 12px; border-radius: 6px; font-size: 0.9rem;">
                    Logic: <strong style="color:#f472b6"><%= ans.logicScore %>/10</strong>
                </div>
            </div>

            <div style="background: rgba(163, 113, 247, 0.05); border: 1px solid rgba(163, 113, 247, 0.2); padding: 15px; border-radius: 8px; margin-bottom: 15px;">
                <div style="font-size: 0.8rem; font-weight: 600; color: #a371f7; margin-bottom: 5px;">AI FEEDBACK</div>
                <p style="margin: 0; line-height: 1.5; color: var(--text-secondary);"><%= ans.feedback %></p>
            </div>

            <% if (ans.idealAnswer) { %>
            <div style="background: rgba(46, 160, 67, 0.05); border: 1px solid rgba(46, 160, 67, 0.2); padding: 15px; border-radius: 8px;">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 5px;">
                    <div style="font-size: 0.8rem; font-weight: 600; color: #3fb950;">IDEAL ANSWER SUGGESTION</div>
                    <button onclick="translateIdealAnswer(this, <%= index %>)" class="btn" style="background: transparent; color: #3fb950; border: 1px solid #3fb950; padding: 4px 8px; font-size: 0.75rem; border-radius: 4px; cursor: pointer;">
                        Translate to Hindi
                    </button>
                </div>
                <p id="ideal-eng-<%= index %>" style="margin: 0; line-height: 1.6; color: var(--text-primary);"><%= ans.idealAnswer %></p>
                <p id="ideal-hin-<%= index %>" style="margin: 10px 0 0 0; line-height: 1.6; color: #4ade80; display: none; padding-top: 10px; border-top: 1px dashed rgba(46, 160, 67, 0.2);"></p>
            </div>
            <% } %>
        </div>
    <% }) %>

</div>

<script>
    async function translateIdealAnswer(btn, index) {
        const engText = document.getElementById(`ideal-eng-${index}`).innerText;
        const hinTextEl = document.getElementById(`ideal-hin-${index}`);
        
        btn.innerText = 'Translating...';
        btn.disabled = true;
        btn.style.opacity = '0.6';

        try {
            const res = await fetch('/interview/translate', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ text: engText })
            });
            const data = await res.json();
            
            if (data.success) {
                hinTextEl.innerText = data.translation;
                hinTextEl.style.display = 'block';
                btn.style.display = 'none'; // hide the button to avoid re-translation
            } else {
                btn.innerText = 'Translation Failed';
                btn.disabled = false;
                btn.style.opacity = '1';
            }
        } catch (e) {
            console.error(e);
            btn.innerText = 'Error - Try Again';
            btn.disabled = false;
            btn.style.opacity = '1';
        }
    }
</script>

<style>
    @media (max-width: 600px) {
        .mobile-hide { display: none; }
    }
</style>

<%- include('../partials/footer') %>