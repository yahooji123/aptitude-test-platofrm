<%- include('../partials/header') %>

<div class="dashboard-banner" style="background: linear-gradient(135deg, #1f6feb 0%, #388bfd 100%);">
    <div class="banner-title">Website UI Handler</div>
    <div class="banner-subtitle">Configure the visuals, themes, and layouts of your platform centrally.</div>
    <div style="margin-top: 15px;">
        <a href="/admin/dashboard" class="btn" style="background: rgba(255,255,255,0.2); color: white; border: none;">&larr; Back to Dashboard</a>
    </div>
</div>

<div class="container" style="max-width: 700px; margin-top: -30px; position: relative; z-index: 2;">
    
    <% if (typeof req !== 'undefined' && req.query.success) { %>
        <div style="background: rgba(46, 160, 67, 0.15); border: 1px solid #3fb950; color: #3fb950; padding: 15px; border-radius: 8px; margin-bottom: 20px; text-align: center; font-weight: 500;">
            UI Preferences updated successfully!
        </div>
    <% } %>

    <div class="quiz-card">
        <h3 style="margin-top: 0; display: flex; align-items: center; gap: 10px;">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#a371f7" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
            Navigation Bar Style
        </h3>
        <p style="color: var(--text-secondary); margin-bottom: 25px; font-size: 0.95rem;">
            Choose between the classic classic layout or the newly designed modern blur-styled navigation bar. 
        </p>

        <form action="/admin/ui-handler" method="POST">
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 30px;">
                
                <!-- Option 1: Classic -->
                <label style="cursor: pointer;">
                    <div style="border: 2px solid <%= (!systemSettings || systemSettings.NAVBAR_STYLE !== 'modern') ? '#58a6ff' : 'var(--border-color)' %>; background: var(--bg-body); border-radius: 12px; padding: 20px; text-align: center; transition: all 0.2s;">
                        <input type="radio" name="navbarStyle" value="default" <%= (!systemSettings || systemSettings.NAVBAR_STYLE !== 'modern') ? 'checked' : '' %> style="display: none;" onchange="this.form.submit()">
                        <div style="height: 4px; width: 60%; background: #30363d; margin: 0 auto 15px; border-radius: 4px;"></div>
                        <h4 style="margin: 0 0 5px 0;">Classic Navbar</h4>
                        <span style="font-size: 0.8rem; color: var(--text-secondary);">Minimal & Text Based</span>
                    </div>
                </label>

                <!-- Option 2: Modern -->
                <label style="cursor: pointer;">
                    <div style="border: 2px solid <%= (systemSettings && systemSettings.NAVBAR_STYLE === 'modern') ? '#58a6ff' : 'var(--border-color)' %>; background: var(--bg-body); border-radius: 12px; padding: 20px; text-align: center; transition: all 0.2s;">
                        <input type="radio" name="navbarStyle" value="modern" <%= (systemSettings && systemSettings.NAVBAR_STYLE === 'modern') ? 'checked' : '' %> style="display: none;" onchange="this.form.submit()">
                        <div style="height: 20px; width: 80%; background: linear-gradient(90deg, #1f6feb, #a371f7); margin: 0 auto 15px; border-radius: 10px; opacity: 0.7;"></div>
                        <h4 style="margin: 0 0 5px 0;">Modern & Advanced</h4>
                        <span style="font-size: 0.8rem; color: var(--text-secondary);">Glassmorphism & Icons</span>
                    </div>
                </label>

            </div>

            <div style="background: rgba(88, 166, 255, 0.05); border: 1px dashed rgba(88, 166, 255, 0.4); padding: 15px; border-radius: 8px; font-size: 0.9rem; color: var(--text-secondary);">
                💡 Selecting an option saves your preference automatically and changes the header layout for all users in real-time.
            </div>
        </form>

    </div>
</div>

<%- include('../partials/footer') %>