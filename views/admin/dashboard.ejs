<%- include('../partials/header') %>

<div class="dashboard-banner" style="background: linear-gradient(135deg, #238636 0%, #2ea043 100%);">
    <div class="banner-title">Admin Control Center</div>
    <div class="banner-subtitle">Manage questions, configure tests, and monitor system performance.</div>
</div>

<!-- Action Links Row -->
<div style="margin-bottom: 20px; display: flex; gap: 15px; flex-wrap: wrap;">
    <a href="/admin/ai-analytics" class="btn btn-primary" style="background: rgba(88, 166, 255, 0.1); color: #58a6ff; border: 1px solid rgba(88, 166, 255, 0.4); display: flex; align-items: center; gap: 8px;">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"></path></svg>
        View AI Analytics & API Usage
    </a>
    <a href="/admin/ui-handler" class="btn btn-primary" style="background: rgba(163, 113, 247, 0.1); color: #a371f7; border: 1px solid rgba(163, 113, 247, 0.4); display: flex; align-items: center; gap: 8px;">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
        Website UI Handler
    </a>
</div>

<!-- Stats Row -->
<div class="cards-grid" style="grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); margin-bottom: 40px;">
    
    <!-- Smart Practice Mode Toggle Card -->
    <div class="admin-stat-card" style="border: 1px solid <%= typeof smartPracticeMode !== 'undefined' && smartPracticeMode ? '#2ea043' : '#30363d' %>; transition: all 0.3s;" id="smartModeCard">
        <div>
            <div class="admin-stat-label">Smart Practice Mode</div>
            <div style="display: flex; align-items: center; gap: 10px; margin-top: 5px;">
                <div class="admin-stat-value" id="smartModeStatus" style="font-size: 1.2rem; color: <%= typeof smartPracticeMode !== 'undefined' && smartPracticeMode ? '#2ea043' : '#8b949e' %>;">
                    <%= typeof smartPracticeMode !== 'undefined' && smartPracticeMode ? 'Active' : 'Disabled' %>
                </div>
                <!-- Toggle Switch -->
                <label class="switch">
                    <input type="checkbox" id="smartModeToggle" <%= typeof smartPracticeMode !== 'undefined' && smartPracticeMode ? 'checked' : '' %> onchange="toggleSetting('smartPracticeMode', this)">
                    <span class="slider round"></span>
                </label>
            </div>
        </div>
        <div style="margin-top: 10px; font-size: 0.8rem; color: #8b949e;">
            Prioritize unseen questions.
        </div>
    </div>

    <!-- AI Essay Grading Toggle Card -->
    <div class="admin-stat-card" style="border: 1px solid <%= typeof aiEssayGrading !== 'undefined' && aiEssayGrading ? '#a371f7' : '#30363d' %>; transition: all 0.3s;" id="aiEssayCard">
        <div>
            <div class="admin-stat-label">AI Essay Grading</div>
            <div style="display: flex; align-items: center; gap: 10px; margin-top: 5px;">
                <div class="admin-stat-value" id="aiEssayStatus" style="font-size: 1.2rem; color: <%= typeof aiEssayGrading !== 'undefined' && aiEssayGrading ? '#a371f7' : '#8b949e' %>;">
                    <%= typeof aiEssayGrading !== 'undefined' && aiEssayGrading ? 'Enabled' : 'Disabled' %>
                </div>
                <!-- Toggle Switch -->
                <label class="switch">
                    <input type="checkbox" id="aiEssayToggle" <%= typeof aiEssayGrading !== 'undefined' && aiEssayGrading ? 'checked' : '' %> onchange="toggleSetting('AI_ESSAY_GRADING_ENABLED', this)">
                    <span class="slider round"></span>
                </label>
            </div>
        </div>
        <div style="margin-top: 10px; font-size: 0.8rem; color: #8b949e;">
            Auto-grade essays with Gemini.
        </div>
    </div>

    <!-- AI Reading Gen Toggle Card -->
    <div class="admin-stat-card" style="border: 1px solid <%= typeof aiReadingGen !== 'undefined' && aiReadingGen ? '#a371f7' : '#30363d' %>; transition: all 0.3s;" id="aiReadingCard">
        <div>
            <div class="admin-stat-label">AI Passage Generator</div>
            <div style="display: flex; align-items: center; gap: 10px; margin-top: 5px;">
                <div class="admin-stat-value" id="aiReadingStatus" style="font-size: 1.2rem; color: <%= typeof aiReadingGen !== 'undefined' && aiReadingGen ? '#a371f7' : '#8b949e' %>;">
                    <%= typeof aiReadingGen !== 'undefined' && aiReadingGen ? 'Enabled' : 'Disabled' %>
                </div>
                <!-- Toggle Switch -->
                <label class="switch">
                    <input type="checkbox" id="aiReadingToggle" <%= typeof aiReadingGen !== 'undefined' && aiReadingGen ? 'checked' : '' %> onchange="toggleSetting('AI_READING_GEN_ENABLED', this)">
                    <span class="slider round"></span>
                </label>
            </div>
        </div>
        <div style="margin-top: 10px; font-size: 0.8rem; color: #8b949e;">
            Generate MCQs from text.
        </div>
    </div>

    <!-- AI Reading Features Toggle Card -->
    <div class="admin-stat-card" style="border: 1px solid <%= typeof aiReadingFeatures !== 'undefined' && aiReadingFeatures ? '#a371f7' : '#30363d' %>; transition: all 0.3s;" id="aiReadingFeaturesCard">
        <div>
            <div class="admin-stat-label">AI Reading Features</div>
            <div style="display: flex; align-items: center; gap: 10px; margin-top: 5px;">
                <div class="admin-stat-value" id="aiReadingFeaturesStatus" style="font-size: 1.2rem; color: <%= typeof aiReadingFeatures !== 'undefined' && aiReadingFeatures ? '#a371f7' : '#8b949e' %>;">
                    <%= typeof aiReadingFeatures !== 'undefined' && aiReadingFeatures ? 'Enabled' : 'Disabled' %>
                </div>
                <!-- Toggle Switch -->
                <label class="switch">
                    <input type="checkbox" id="aiReadingFeaturesToggle" <%= typeof aiReadingFeatures !== 'undefined' && aiReadingFeatures ? 'checked' : '' %> onchange="toggleSetting('AI_READING_FEATURES_ENABLED', this)">
                    <span class="slider round"></span>
                </label>
            </div>
        </div>
        <div style="margin-top: 10px; font-size: 0.8rem; color: #8b949e;">
            Student translation, highlight & explain tools.
        </div>
    </div>

    <!-- AI Chat Toggle Card -->
    <div class="admin-stat-card" style="border: 1px solid <%= typeof aiChat !== 'undefined' && aiChat ? '#a371f7' : '#30363d' %>; transition: all 0.3s;" id="aiChatCard">
        <div>
            <div class="admin-stat-label">✨ AI Chat</div>
            <div style="display: flex; align-items: center; gap: 10px; margin-top: 5px;">
                <div class="admin-stat-value" id="aiChatStatus" style="font-size: 1.2rem; color: <%= typeof aiChat !== 'undefined' && aiChat ? '#a371f7' : '#8b949e' %>;">
                    <%= typeof aiChat !== 'undefined' && aiChat ? 'Enabled' : 'Disabled' %>
                </div>
                <!-- Toggle Switch -->
                <label class="switch">
                    <input type="checkbox" id="aiChatToggle" <%= typeof aiChat !== 'undefined' && aiChat ? 'checked' : '' %> onchange="toggleSetting('AI_CHAT_ENABLED', this)">
                    <span class="slider round"></span>
                </label>
            </div>
        </div>
        <div style="margin-top: 10px; font-size: 0.8rem; color: #8b949e;">
            Global student AI tutor queries.
        </div>
    </div>

    <!-- AI Live Essay Check Toggle Card -->
    <div class="admin-stat-card" style="border: 1px solid <%= typeof aiLiveEssayCheck !== 'undefined' && aiLiveEssayCheck ? '#a371f7' : '#30363d' %>; transition: all 0.3s;" id="aiLiveCheckCard">
        <div>
            <div class="admin-stat-label">Live AI Essay Help</div>
            <div style="display: flex; align-items: center; gap: 10px; margin-top: 5px;">
                <div class="admin-stat-value" id="aiLiveCheckStatus" style="font-size: 1.2rem; color: <%= typeof aiLiveEssayCheck !== 'undefined' && aiLiveEssayCheck ? '#a371f7' : '#8b949e' %>;">
                    <%= typeof aiLiveEssayCheck !== 'undefined' && aiLiveEssayCheck ? 'Enabled' : 'Disabled' %>
                </div>
                <!-- Toggle Switch -->
                <label class="switch">
                    <input type="checkbox" id="aiLiveCheckToggle" <%= typeof aiLiveEssayCheck !== 'undefined' && aiLiveEssayCheck ? 'checked' : '' %> onchange="toggleSetting('AI_LIVE_ESSAY_CHECK_ENABLED', this)">
                    <span class="slider round"></span>
                </label>
            </div>
        </div>
        <div style="margin-top: 10px; font-size: 0.8rem; color: #8b949e;">
            5 credits/essay during writing.
        </div>
    </div>

    <div class="admin-stat-card">
        <div>
            <div class="admin-stat-label">Total Questions</div>
            <div class="admin-stat-value"><%= questionCount %></div>
        </div>
        <div style="margin-top: 15px;">
            <a href="/admin/questions" class="btn btn-nav-login" style="display:inline-block; font-size: 0.9rem;">View All &rarr;</a>
        </div>
    </div>
</div>

<!-- Main Content Grid -->
<div class="dashboard-grid">
    
    <!-- Active Tests Table -->
    <div class="grid-wide">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
            <h3 style="margin: 0;">Configuration & Tests</h3>
            <a href="/admin/tests/create" class="btn btn-nav-signup">+ Create New Test</a>
        </div>

        <div class="quiz-card" style="padding: 0; border: none; overflow: hidden;">
            <table>
                <thead>
                    <tr>
                        <th width="35%">Title</th>
                        <th>Type</th>
                        <th>Questions</th>
                        <th>Duration</th>
                        <th>Status</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (typeof tests !== 'undefined' && tests.length > 0) { %>
                        <% tests.forEach(test => { %>
                            <tr>
                                <td style="font-weight: 600; color: white;">
                                    <%= test.title %>
                                    <div style="font-size: 0.75rem; color: #8b949e; margin-top: 4px;">
                                        <%= test.tags.join(', ') %>
                                    </div>
                                </td>
                                <td>
                                    <% if(test.category === 'Test') { %>
                                        <span class="status-badge" style="background: rgba(238, 75, 43, 0.1); color: #ff7b72; border-color: rgba(238, 75, 43, 0.4);">Test</span>
                                    <% } else { %>
                                        <span class="status-badge">Practice</span>
                                    <% } %>
                                </td>
                                <td><%= test.totalQuestions %></td>
                                <td><%= test.duration %>m</td>
                                <td>
                                    <% if(test.isActive) { %>
                                        <span style="color: #238636;">● Active</span>
                                    <% } else { %>
                                        <span style="color: #8b949e;">○ Draft</span>
                                    <% } %>
                                </td>
                                <td>
                                    <div style="display: flex; gap: 10px; align-items: center;">
                                        <a href="/admin/tests/edit/<%= test._id %>" style="color: var(--accent-color); text-decoration: none; font-size: 0.9rem;">Edit</a>
                                        <form action="/admin/tests/delete/<%= test._id %>" method="POST" onsubmit="return confirm('Are you sure you want to delete this test? This will also remove associated student results.');" style="margin:0;">
                                            <button type="submit" style="background: none; border: none; color: #f85149; cursor: pointer; font-size: 0.9rem;">Delete</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="6" style="text-align: center; padding: 40px; color: #8b949e;">
                                No test configurations found. Create one to get started!
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>

            <!-- Pagination Controls -->
            <% if (typeof totalPages !== 'undefined' && totalPages > 1) { %>
            <div style="display: flex; justify-content: center; padding: 20px; gap: 10px; border-top: 1px solid #30363d;">
                <% if (currentPage > 1) { %>
                    <a href="?page=<%= currentPage - 1 %>" style="background: transparent; border: 1px solid #30363d; color: #c9d1d9; padding: 6px 12px; border-radius: 6px; text-decoration: none; font-size: 0.9rem;">&larr; Prev</a>
                <% } %>
                
                <span style="background: #161b22; border: 1px solid #30363d; color: #58a6ff; padding: 6px 12px; border-radius: 6px; font-size: 0.9rem;">
                    Page <%= currentPage %> of <%= totalPages %>
                </span>

                <% if (currentPage < totalPages) { %>
                    <a href="?page=<%= currentPage + 1 %>" style="background: transparent; border: 1px solid #30363d; color: #c9d1d9; padding: 6px 12px; border-radius: 6px; text-decoration: none; font-size: 0.9rem;">Next &rarr;</a>
                <% } %>
            </div>
            <% } %>

        </div>
    </div>

    <!-- Quick Actions -->
    <div>
        <h3 style="margin-bottom: 20px;">Quick Actions</h3>
        
        <div class="quiz-card" style="display: flex; flex-direction: column; gap: 15px;">
            <a href="/admin/students" class="btn" style="text-align: center; background: #21262d; color: var(--text-primary); padding: 12px; border-radius: 6px; text-decoration: none; border: 1px solid var(--border-color); transition: 0.2s;">
                User Management
            </a>
            <a href="/admin/questions" class="btn" style="text-align: center; background: #21262d; color: var(--text-primary); padding: 12px; border-radius: 6px; text-decoration: none; border: 1px solid var(--border-color); transition: 0.2s;">
                Database Manager
            </a>
            <a href="/admin/tests/create" class="btn" style="text-align: center; background: #21262d; color: var(--text-primary); padding: 12px; border-radius: 6px; text-decoration: none; border: 1px solid var(--border-color); transition: 0.2s;">
                New Configuration
            </a>
            
            <div style="height: 1px; background: var(--border-color); margin: 10px 0;"></div>

            <div style="font-size: 0.85rem; color: #8b949e;">
                <strong>Tip:</strong> Create "Practice Sets" for specific topics like Arrays or DP to let students train without pressure.
            </div>
        </div>
    </div>

</div>

<script>
    async function toggleSetting(key, checkbox) {
        let statusLabel, card, activeColor;
        
        if (key === 'smartPracticeMode') {
            statusLabel = document.getElementById('smartModeStatus');
            card = document.getElementById('smartModeCard');
            activeColor = '#2ea043';
        } else if (key === 'AI_ESSAY_GRADING_ENABLED') {
            statusLabel = document.getElementById('aiEssayStatus');
            card = document.getElementById('aiEssayCard');
            activeColor = '#a371f7';
        } else if (key === 'AI_READING_GEN_ENABLED') {
            statusLabel = document.getElementById('aiReadingStatus');
            card = document.getElementById('aiReadingCard');
            activeColor = '#a371f7';
        } else if (key === 'AI_LIVE_ESSAY_CHECK_ENABLED') {
            statusLabel = document.getElementById('aiLiveCheckStatus');
            card = document.getElementById('aiLiveCheckCard');
            activeColor = '#a371f7';
        } else if (key === 'AI_READING_FEATURES_ENABLED') {
            statusLabel = document.getElementById('aiReadingFeaturesStatus');
            card = document.getElementById('aiReadingFeaturesCard');
            activeColor = '#a371f7';
        } else if (key === 'AI_CHAT_ENABLED') {
            statusLabel = document.getElementById('aiChatStatus');
            card = document.getElementById('aiChatCard');
            activeColor = '#a371f7';
        }
        
        // Optimistic UI Update
        const isChecked = checkbox.checked;
        statusLabel.textContent = isChecked ? (key === 'smartPracticeMode' ? 'Active' : 'Enabled') : 'Disabled';
        statusLabel.style.color = isChecked ? activeColor : '#8b949e';
        card.style.borderColor = isChecked ? activeColor : '#30363d';

        try {
            const res = await fetch('/admin/settings/toggle', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ key })
            });
            const data = await res.json();
            if(!data.success) {
                // Revert on failure
                checkbox.checked = !isChecked;
                alert('Failed to update setting');
                window.location.reload();
            }
        } catch (err) {
            console.error(err);
            checkbox.checked = !isChecked; // Revert
            alert('Error updating setting');
            window.location.reload();
        }
    }
</script>

<style>
    .dashboard-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 30px;
    }
    .grid-wide {
        grid-column: span 2;
    }
    @media (max-width: 1024px) {
        .grid-wide {
            grid-column: auto;
        }
    }
    @media (max-width: 768px) {
         .dashboard-grid {
            grid-template-columns: 1fr;
            gap: 20px;
         }
    }
    
    /* Toggle Switch Styles */
    .switch {
      position: relative;
      display: inline-block;
      width: 40px;
      height: 20px;
    }
    .switch input { opacity: 0; width: 0; height: 0; }
    .slider {
      position: absolute;
      cursor: pointer;
      top: 0; left: 0; right: 0; bottom: 0;
      background-color: #30363d;
      transition: .4s;
    }
    .slider:before {
      position: absolute;
      content: "";
      height: 14px;
      width: 14px;
      left: 3px;
      bottom: 3px;
      background-color: white;
      transition: .4s;
    }
    input:checked + .slider { background-color: #2ea043; }
    input:checked + .slider:before { transform: translateX(20px); }
    .slider.round { border-radius: 20px; }
    .slider.round:before { border-radius: 50%; }

</style>

<%- include('../partials/footer') %>
